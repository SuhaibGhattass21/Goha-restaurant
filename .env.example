# Production environment for Docker Compose + Nginx reverse proxy

# Application
NODE_ENV=production
PORT=3000
APP_VERSION=1.0.0
API_URL=https://api.example.com/api/v1
ALLOWED_ORIGINS=https://app.example.com,https://api.example.com
SERVER_NAME=api.example.com

# Database
DATABASE_URL=postgresql://postgres:postgres@db:5432/postgres
DATABASE_SSL=false

# Authentication
JWT_SECRET=change-me
JWT_REFRESH_SECRET=change-me-too
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d
BCRYPT_ROUNDS=12

# Reverse proxy TLS
# The proxy listens on 80 and 443.
# HTTP on 80 redirects to HTTPS on 443.
TLS_CERT_PATH=/etc/nginx/certs/fullchain.pem
TLS_KEY_PATH=/etc/nginx/certs/privkey.pem

# Optional: enable built-in HTTPS in the Node app only if you are not using the proxy
HTTPS_ENABLED=false
HTTPS_KEY_PATH=
HTTPS_CERT_PATH=
HTTPS_PASSPHRASE=

# Logging
LOG_LEVEL=info
ENABLE_FILE_LOGGING=true
ENABLE_CONSOLE_LOGGING=true
ENABLE_DB_LOGGING=false
LOG_MAX_FILE_SIZE=20m
LOG_MAX_FILES=14d
LOG_DIRECTORY=logs
LOG_ROTATION_INTERVAL=daily
LOG_COMPRESSION_ENABLED=false
LOG_SANITIZATION_ENABLED=true

# Monitoring
TRACK_MEMORY_USAGE=true
TRACK_CPU_USAGE=true
SLOW_QUERY_THRESHOLD=1000
SLOW_REQUEST_THRESHOLD=5000
PERFORMANCE_SAMPLING_RATE=1.0
SECURITY_LOGGING_ENABLED=true
TRACK_FAILED_LOGINS=true
TRACK_AUTH_FAILURES=true
SUSPICIOUS_ACTIVITY_THRESHOLD=5
BLOCK_SUSPICIOUS_IPS=false
