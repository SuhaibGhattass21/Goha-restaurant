# Core runtime
NODE_ENV=development
PORT=3000
APP_VERSION=1.0.0

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/goha_restaurant
DATABASE_SSL=false

# API and auth
API_URL=http://localhost:3000/api/v1
ALLOWED_ORIGINS=http://localhost:3000
JWT_SECRET=change-me
JWT_EXPIRY=7d
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change-me-too
BCRYPT_ROUNDS=12

# Logging
LOG_LEVEL=info
ENABLE_FILE_LOGGING=true
ENABLE_CONSOLE_LOGGING=true
ENABLE_DB_LOGGING=false
LOG_MAX_FILE_SIZE=20m
LOG_MAX_FILES=14d
LOG_DIRECTORY=logs
LOG_ROTATION_INTERVAL=daily
LOG_COMPRESSION_ENABLED=false
LOG_SANITIZATION_ENABLED=true
TRACK_MEMORY_USAGE=true
TRACK_CPU_USAGE=true
SLOW_QUERY_THRESHOLD=1000
SLOW_REQUEST_THRESHOLD=5000
PERFORMANCE_SAMPLING_RATE=1.0
SECURITY_LOGGING_ENABLED=true
TRACK_FAILED_LOGINS=true
TRACK_AUTH_FAILURES=true
SUSPICIOUS_ACTIVITY_THRESHOLD=5
BLOCK_SUSPICIOUS_IPS=false

# Alerts and notifications
ALERTING_ENABLED=false
ALERT_ERROR_RATE=0.05
ALERT_MEMORY_USAGE=512
ALERT_CPU_USAGE=80
ALERT_RESPONSE_TIME=5000
ALERT_DISK_SPACE=85
EMAIL_NOTIFICATIONS_ENABLED=false
EMAIL_RECIPIENTS=
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SLACK_NOTIFICATIONS_ENABLED=false
SLACK_WEBHOOK_URL=
SLACK_CHANNEL=#alerts
WEBHOOK_NOTIFICATIONS_ENABLED=false
WEBHOOK_URL=
WEBHOOK_HEADERS=
SENSITIVE_FIELDS=password,token,authorization
MASKING_CHAR=*
MASKING_STRATEGY=partial

# HTTPS deployment on a VM
HTTPS_ENABLED=false
HTTPS_KEY_PATH=
HTTPS_CERT_PATH=
HTTPS_PASSPHRASE=# Production Environment Configuration Template
# Copy this file to .env and fill in your values

# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/goha_restaurant
# Set to "true" only for external production databases that require SSL
DATABASE_SSL=false

# Application Configuration
NODE_ENV=production
PORT=3000
API_URL=http://localhost:3000/api/v1

# JWT Configuration (Generate strong secrets for production)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_this_in_production
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Logging Level (error, warn, info, debug)
LOG_LEVEL=info

# Optional: Email Configuration (if you plan to add email features)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-email-password

# Optional: Redis Configuration (if you plan to add caching)
# REDIS_URL=redis://localhost:6379

# Optional: File Upload Configuration
MAX_FILE_SIZE=10mb
UPLOAD_DIR=./uploads
